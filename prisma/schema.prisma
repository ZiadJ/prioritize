model ComposableNode {
  id        Int      @id @default(autoincrement())
  updateAt  DateTime @updatedAt
  createdAt DateTime @default(now())
  isActive  Boolean

  path     String           @unique // An auto-generated list of ids alllowing quick access to parents
  depth    Int
  numchild Int              @default(0)
  parent   ComposableNode?  @relation("Self", fields: [parentId], references: [id])
  parentId Int
  children ComposableNode[] @relation("Self")

  //composableNodeId Int

  @@index([path])
}

