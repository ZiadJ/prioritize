model User {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  firstname     String    @default("")
  lastname      String    @default("")
  username      String    @unique
  email         String    @unique
  password      String
  bio           String    @default("")
  picture       String?
  githubId      String?   @unique
  tokenVersion  Int       @default(0)
  lastTimeVisit DateTime?
  dateOfBirth   DateTime?
  longitude     Int       @default(0) // For delivery cost estimation
  lattitude     Int       @default(0)
  preferences   Json      @default("{}") // Json(no Sqlite support)
  isVerified    Boolean   @default(false)

  tokens Token[]

  expertise         ExpertiseNode[]
  steps             StepNode[]      @relation("AssignedSteps")
  feedback          FeedbackNode[]
  revisions         RevisionNode[]
  tags              Tag[]
  fromRelationships UserRelation[]  @relation("from")
  toRelationships   UserRelation[]  @relation("to")

  editableRequests      Request[]         @relation("requestEditors")
  ownedRequests         Request[]         @relation("RequestOwner")
  editableRequestNodes  RequestNode[]     @relation("RequestNodeEditors")
  ownedRequestNodes     RequestNode[]     @relation("RequestNodeOwner")
  editableProposals     Proposal[]        @relation("ProposalEditors")
  ownedProposals        Proposal[]        @relation("ProposalOwner")
  editableStepNodes     StepNode[]        @relation("StepNodeEditors")
  ownedStepNodes        StepNode[]        @relation("StepNodeOwner")
  editableStepCosts     StepCost[]        @relation("StepCostEditors")
  ownedStepCosts        StepCost[]        @relation("StepCostOwner")
  editableResourceNodes ResourceNode[]    @relation("ResourceNodeEditors")
  ownedResourceNodes    ResourceNode[]    @relation("ResourceNodeOwner")
  
  requestQuantities     RequestQuantity[]
}

model Token {
  id           Int      @id @default(autoincrement())
  accessToken  String   @unique
  refreshToken String   @unique
  createdAt    DateTime @default(now())
  expiresAt    DateTime // Fecha de expiración del token

  user   User   @relation(fields: [userId], references: [id])
  userId String
}

model UserRelation {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  type String @default("friend")

  from   User   @relation("from", fields: [fromId], references: [id])
  fromId String
  to     User   @relation("to", fields: [toId], references: [id])
  toId   String
}

// Revision information that are applied to the targeted row 
// and column after approval

model RevisionNode {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title   String // @unique
  body    String
  isDirty Boolean? // Client-server-clients sync flag
  // revisions   Revision[] 

  path     String         @unique
  depth    Int            @default(0)
  numchild Int            @default(0)
  parent   RevisionNode?  @relation("Self", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  children RevisionNode[] @relation("Self")

  data          String // Json(no Sqlite support)
  type          Int // RevisionType // Self, Suggestion, Deduplication, ModeratorFlag
  isApproved    Boolean // Based on feedback ratings but is not required for self revisions
  approvedAt    DateTime
  isLastApplied Boolean // Is the last applied version
  isRejected    Boolean // Based on feedback ratings
  rejectedAt    DateTime

  feedback FeedbackNode[]

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  request         Request?       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId       Int?
  RequestNode     RequestNode?   @relation(fields: [requestNodeId], references: [id], onDelete: Cascade)
  requestNodeId   Int?
  proposalNode    Proposal?      @relation(fields: [proposalNodeId], references: [id], onDelete: Cascade)
  proposalNodeId  Int?
  Step            StepNode?      @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId          Int?
  stepCost        StepCost?      @relation(fields: [stepCostId], references: [id], onDelete: Cascade)
  stepCostId      Int?
  effect          Effect?        @relation(fields: [effectId], references: [id], onDelete: Cascade)
  effectId        Int?
  expertiseNode   ExpertiseNode? @relation(fields: [expertiseNodeId], references: [id], onDelete: Cascade)
  expertiseNodeId Int?
  resourceNode    ResourceNode?  @relation(fields: [resourceNodeId], references: [id], onDelete: Cascade)
  resourceNodeId  Int?
  effectHook      Effector?      @relation(fields: [effectHookId], references: [id], onDelete: Cascade)
  effectHookId    Int?

  //@@unique([userId, requestId, requestId, requestNodeId, proposalId, proposalNodeId, stepId, stepCostId, effectId, expertiseNodeId, resourceNodeId, effectHookId])
  @@index([path])
}

model CognitiveBias {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title            String  @unique
  description      String
  isLogicalFallacy Boolean
  courseUrl        String

  AssignedCognitiveBias AssignedCognitiveBias[]
}

model AssignedCognitiveBias {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title      String  @unique
  body       String
  isResolved Boolean

  cognitiveBias   CognitiveBias @relation(fields: [cognitiveBiasId], references: [id], onDelete: Cascade)
  cognitiveBiasId Int
  proposalNode    Proposal      @relation(fields: [proposalNodeId], references: [id], onDelete: Cascade)
  proposalNodeId  Int
  requestNode     RequestNode   @relation(fields: [requestNodeId], references: [id], onDelete: Cascade)
  requestNodeId   Int
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique
  type String @default("request")

  users        User[]
  request      Request[]
  requestNode  RequestNode[]
  proposalNode Proposal[]
  step         StepNode[]
  stepCost     StepCost[]
  effect       Effect[]
  resourceNode ResourceNode[]

  @@unique([name, type])
  @@index([name])
}

// A composable expertise allowing one to make attributions 
// to specific user requestNodes

model ExpertiseNode {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title     String         @unique
  body      String
  isDirty   Boolean? // Client->server->clients sync flag
  revisions RevisionNode[]

  path     String          @unique
  depth    Int             @default(0)
  numchild Int             @default(0)
  parent   ExpertiseNode?  @relation("Self", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  children ExpertiseNode[] @relation("Self")

  users     User[]
  interests Request[]
  effects   Effect[]

  @@index([path])
}

model Request {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean  @default(true)

  title     String         @unique
  body      String
  isDirty   Boolean? // Client-server-clients sync flag
  revisions RevisionNode[]

  // Variant hierarchy for similar requests with different parameters
  path     String    @unique @default("")
  depth    Int       @default(0)
  numchild Int       @default(0)
  parent   Request?  @relation("Self", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  children Request[] @relation("Self")

  type  Int // RequestType // Verbal, Material
  level Int // RequestLevel // Safety, Health, Belonging, Esteem, SelfActualization

  recurrencePeriod Int // For reccurring requests such as daily water intake or weekly social interactions

  requests   RequestNode[]
  expertise  ExpertiseNode[]
  feedback   FeedbackNode[]
  tags       Tag[]
  effects    Effect[]
  quantities RequestQuantity[]

  owner   User   @relation("RequestOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String
  editors User[] @relation("requestEditors")

  @@index([path])
}

// Tracks the quantity of material requested by a user for a material-type request
model RequestQuantity {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean  @default(true)

  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  quantity      Float
  unitOfMeasure Int? // UnitOfMeasure, null when using custom units
  customUnit    String? // e.g. "pizzas", "meetings", "trees"

  @@unique([requestId, userId])
  @@index([requestId])
  @@index([userId])
}

// A request containing proposal nodes each assignable to a step. Each
// node is weighed in terms of expert-based costs and side-effects

model RequestNode {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title     String         @unique
  body      String
  isDirty   Boolean? // Client-to-server synched
  revisions RevisionNode[]

  path     String        @unique
  depth    Int           @default(0)
  numchild Int           @default(0)
  parent   RequestNode?  @relation("Self", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  children RequestNode[] @relation("Self")

  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId Int

  position Int // For ordering within a parent node

  isTemplate      Boolean // Is an abstract template for new requests
  isVariantsGroup Boolean // Contains a list of variant nodes requested by different users
  isNonNegotiable Boolean

  // alignedProposalFeedback FeedbackNode[] // Feeback ratings for the level of alignment with a proposal node(could be 'impact' instead of 'alignment')
  tags                  Tag[]
  assignedCognitiveBias AssignedCognitiveBias[]

  relatedProblems  RequestNode[] @relation("RelatedRequests")
  relatedSolutions RequestNode[] @relation("RelatedRequests") // Already resolved requests dealing with similar problems

  requestedAt DateTime? @default(now())
  deliveryAt  DateTime? // Urgency

  // conflictingInterests Request[]      @relation("ConflictOfInterest") // Can be auto-generated from the requestNodes tree
  proposals Proposal[] // Auto-generated when adding proposed steps

  // Auto-generated when adding feedback to proposed steps
  feedback FeedbackNode[]

  owner   User   @relation("RequestNodeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String
  editors User[] @relation("RequestNodeEditors")

  @@index([path])
}

// A plan, proposal or offer aimed at satisfying a specific request 
// which can have both beneficial and detrimental impacts

// User-rated entity relating request nodes with proposals through
// impact-potential feedback, costs and side-effects.

model Proposal {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title     String         @unique
  body      String
  isDirty   Boolean? // Client-server-clients sync flag
  revisions RevisionNode[]

  // Variants
  path     String     @unique
  depth    Int        @default(0)
  numchild Int        @default(0)
  parent   Proposal?  @relation("Self", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  children Proposal[] @relation("Self")

  requestNodeId Int
  step          StepNode @relation(fields: [stepNodeId], references: [id])
  stepNodeId    Int

  isComplete Boolean // Is true upon completion of all children if any
  stepCount  Int // Determines the amount of resources required depending on associated step
  startsAt   DateTime?
  duration   Int // Proposal duration which can be calculated from child nodes if any
  priority   Int // Only necessary when isSequential is true on parent node
  riskFactor Int
  // isVariantsGroup Boolean // Children are variants 

  approvedAt   DateTime?
  deliveryDays Int // Proposal preparation time
  avgRating    Int       @default(0) // Average of the product feedback ratings from proposal step, request nodes and effects
  minRating    Int
  maxRating    Int

  isTemplate    Boolean // Is an abstract template for new proposals
  isDraft       Boolean?
  isUnavailable Boolean?

  requestNodeImpact     FeedbackNode[] // Voted feedback from experts based on the related interests
  requests              RequestNode[]
  tags                  Tag[]
  assignedCognitiveBias AssignedCognitiveBias[]

  owner   User   @relation("ProposalOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String
  editors User[] @relation("ProposalEditors")

  @@index([path])
}

// An action item or task which is referenced by proposals to 
// specific requests 

model StepNode {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title     String         @unique
  body      String
  isDirty   Boolean? // Client-server-clients sync flag
  revisions RevisionNode[]

  // Parallel steps
  path     String     @unique
  depth    Int        @default(0)
  numchild Int        @default(0)
  parent   StepNode?  @relation("Self", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  children StepNode[] @relation("Self")

  // Sequential steps
  nextId   Int?      @unique
  next     StepNode? @relation("Sibbling", fields: [nextId], references: [id])
  previous StepNode? @relation("Sibbling")

  ResourceNode   ResourceNode? @relation(fields: [resourceNodeId], references: [id])
  resourceNodeId Int?

  duration         Int
  durationVariance Int

  proposalNodes Proposal[]
  costs         StepCost[]
  effects       Effect[]
  assignedTo    User[]     @relation("AssignedSteps")
  tags          Tag[]

  owner   User   @relation("StepNodeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String
  editors User[] @relation("StepNodeEditors")

  @@index([path])
}

// Resource quantity produced or consumed by a specific proposal step

model StepCost {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title     String         @unique
  body      String
  isDirty   Boolean? // Client-server-clients sync flag
  revisions RevisionNode[]

  resourceNode   ResourceNode? @relation(fields: [resourceNodeId], references: [id])
  resourceNodeId Int?
  stepNode       StepNode?     @relation(fields: [stepNodeId], references: [id])
  stepNodeId     Int?

  duration          Int
  riskFactor        Int
  isOpportunistic   Boolean // True when cost is negative 
  quantity          Float // A negative value denotes a production output rather than a cost
  quantityMargin    Float
  costVariationType Int // Linear, Exponential, Custom

  tags Tag[]

  owner   User   @relation("StepCostOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String
  editors User[] @relation("StepCostEditors")

  @@unique([resourceNodeId, stepNodeId])
}

// A impacting side-effect when a request node is enacted upon

model Effect {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title     String         @unique
  body      String
  isDirty   Boolean? // Client-server-clients sync flag
  revisions RevisionNode[]

  request   Request? @relation(fields: [requestId], references: [id])
  requestId Int?

  isOpportunistic Boolean // Side-effect is beneficial
  delay           Int
  duration        Int
  relationType    RelationType
  relationFormula String

  steps    StepNode[]
  feedback FeedbackNode[]
  tags     Tag[]

  effectorFrom Effector[]      @relation("from")
  effectorTo   Effector[]      @relation("to")
  expertise    ExpertiseNode[]
}

// A uni-directional linkage between two effects

model Effector {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title     String         @unique
  body      String
  isDirty   Boolean? // Client-server-clients sync flag
  revisions RevisionNode[]

  from   Effect @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  fromId Int
  to     Effect @relation("to", fields: [toId], references: [id], onDelete: Cascade)
  toId   Int

  strength Int

  @@unique([fromId, toId])
}

// Availability of a specific resource used or produced through 
// associated proposal steps

model ResourceNode {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  title     String         @unique
  body      String
  isDirty   Boolean? // Client-server-clients sync flag
  revisions RevisionNode[]

  path     String         @unique
  depth    Int            @default(0)
  numchild Int            @default(0)
  parent   ResourceNode?  @relation("Self", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  children ResourceNode[] @relation("Self")

  type                   Int // ResourceType // ServiceTime, Material, Digital
  unitOfMeasure          Int // UnitOfMeasure // Unit, Time, Energy, Weight, Volume, Area, Length
  quantityAvailable      Float
  renewalCapacity        Float
  managedRenewalCapacity Float
  minQuantity            Float
  reservedQuantity       Float
  monetaryValue          Float // Per specified unit

  stepsPerAdditionalRenewalCapacity StepNode[] // 
  stepCosts                         StepCost[] // Step cost referencing this resource node
  tags                              Tag[]

  owner   User   @relation("ResourceNodeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String
  editors User[] @relation("ResourceNodeEditors")

  @@index([path])
}
