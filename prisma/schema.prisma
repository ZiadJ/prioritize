//                                               ENUMS FOR SUPPORTING DATABASES
// enum FeedbackType {
//   User
//   Revision
//   Request
//   Interest
//   RequestNode
//   Effect
//   ProposalNode
// }

enum RevisionType {
  Self
  Suggestion
  Deduplication
  ModeratorFlag
}

enum relationType {
  Enabler
  Disabler
  Multiplier
  Incrementor
}

enum ResourceType {
  ServiceTime
  Material
  Digital
}

enum InterestType {
  Emotional
  Observational
  Material
}

enum InterestLevel {
  Safety
  Health
  Belonging
  Esteem
  SelfActualization
}

enum UnitOfMeasure {
  Unit
  Time
  Energy
  Weight
  Volume
  Area
  Length
}

model FeedbackNode {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  path     String         @unique
  depth    Int
  numchild Int            @default(0)
  parent   FeedbackNode?  @relation("Self", fields: [parentId], references: [id])
  parentId Int
  children FeedbackNode[] @relation("Self")

  user                User    @relation(fields: [userId], references: [id])
  userId              String
  type                Int
  rating              Int
  confidence          Int
  // type                Int // FeedbackType // User, Revision, Request, Interest, RequestNode, Effect, ProposalStep
  // targetId            String
  title               String
  description         String
  requireCommentOnNeg Boolean // Require a comment for negative feedback unless a related rating is specified

  Revisions RevisionNode[]

  interestNode   InterestNode? @relation(fields: [interestNodeId], references: [id], onDelete: Cascade)
  interestNodeId Int?
  RequestNode    RequestNode?  @relation(fields: [requestNodeId], references: [id], onDelete: Cascade)
  requestNodeId  Int?
  proposalNode   ProposalNode? @relation(fields: [proposalNodeId], references: [id], onDelete: Cascade)
  proposalNodeId Int?
  effect         Effect?       @relation(fields: [effectId], references: [id], onDelete: Cascade)
  effectId       Int?
  request        RequestNode?  @relation("RequestFeedback", fields: [requestId], references: [id], onDelete: Cascade)
  requestId      Int?
  urgency        RequestNode?  @relation("RequestUrgency", fields: [urgencyId], references: [id], onDelete: Cascade)
  urgencyId      Int?

  // Omitting userId to allow a user to offer multiple feedbacks to another user
  @@unique([interestNodeId, requestNodeId, proposalNodeId, effectId, requestId, urgencyId])
  @@index([path])
  @@map("Feedback")
}

