//                                               ENUMS FOR SUPPORTING DATABASES
// enum FeedbackType {
//   User
//   Revision
//   Request
//   Interest
//   RequestNode
//   Effect
//   ProposalNode
// }

enum RevisionType {
  Self
  Suggestion
  Deduplication
  ModeratorFlag
}

enum RelationType {
  Enabler
  Disabler
  Multiplier
  Incrementor
}

enum ResourceType {
  ServiceTime
  Material
  Digital
}

enum RequestType {
  Emotional
  Observational
  Material
}

enum RequestLevel {
  Safety
  Health
  Belonging
  Esteem
  SelfActualization
}

enum UnitOfMeasure {
  Unit
  Time
  Energy
  Weight
  Volume
  Area
  Length
}

model FeedbackNode {
  id         Int      @id @default(autoincrement())
  modifiedAt DateTime @updatedAt
  createdAt  DateTime @default(now())
  isActive   Boolean

  path     String         @unique
  depth    Int            @default(0)
  numchild Int            @default(0)
  parent   FeedbackNode?  @relation("Self", fields: [parentId], references: [id])
  parentId Int?
  children FeedbackNode[] @relation("Self")

  user                User    @relation(fields: [userId], references: [id])
  userId              String
  type                Int
  rating              Int
  confidence          Int
  // type                Int // FeedbackType // User, Revision, Request, Interest, RequestNode, Effect, ProposalStep
  // targetId            String
  title               String
  description         String
  requireCommentOnNeg Boolean // Require a comment for negative feedback unless a related rating is specified

  Revisions RevisionNode[]

  request        Request?     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId      Int?
  RequestNode    RequestNode? @relation(fields: [requestNodeId], references: [id], onDelete: Cascade)
  requestNodeId  Int?
  proposalNode   Proposal?    @relation(fields: [proposalNodeId], references: [id], onDelete: Cascade)
  proposalNodeId Int?
  effect         Effect?      @relation(fields: [effectId], references: [id], onDelete: Cascade)
  effectId       Int?

  // Omitting userId to allow a user to offer multiple feedbacks to another user
  @@unique([requestId, requestNodeId, proposalNodeId, effectId])
  @@index([path])
}

